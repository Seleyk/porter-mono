{
  "expo": {
    "name": "Porter",
    "slug": "porter-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0F14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.porter.customer"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0F14"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.porter.customer"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.porter.customer",
          "enableGooglePay": false
        }
      ],
      "@rnmapbox/maps",
      ["@react-native-google-signin/google-signin", {
        "iosUrlScheme": "com.googleusercontent.apps.166537216294-m3nem8fttfkuj0k62fja5j8bkgmacbbk"
      }]
    ],
    "scheme": "porter"
  }
}
